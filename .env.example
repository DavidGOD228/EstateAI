# --- Runtime ---
NODE_ENV=development
PORT=3001

# --- Database ---
POSTGRES_USER=estate
POSTGRES_PASSWORD=change-me
POSTGRES_DB=estateai
DATABASE_URL=postgres://estate:change-me@localhost:5432/estateai

# --- Auth ---
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=2h
COOKIE_SECRET=change-me-another-long-random-string

# --- AI (server-side only, never exposed to the browser) ---
AI_PROVIDER=anthropic
AI_MODEL=your-claude-opus-model-name
ANTHROPIC_API_KEY=
AI_TIMEOUT_MS=20000
AI_MAX_QUESTION_LENGTH=500
AI_MAX_OPTIONAL_FEATURES_LENGTH=1000
AI_RATE_LIMIT_TTL_MS=60000
AI_RATE_LIMIT_LIMIT=10
